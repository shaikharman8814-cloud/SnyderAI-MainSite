# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for sending professional emails via Resend.
# Get your key at https://resend.com
RESEND_API_KEY=

# FIREBASE_SERVICE_ACCOUNT: Required for generating custom password reset links.
# Get this from Firebase Console > Project Settings > Service Accounts.
# Paste the entire JSON content from the generated private key file here.
FIREBASE_SERVICE_ACCOUNT=
